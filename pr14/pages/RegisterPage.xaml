<Page x:Class="pr14.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация">
    <Grid>
        <StackPanel Width="350" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Регистрация" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="Email:" Margin="0,0,0,5"/>
            <TextBox x:Name="EmailBox" Margin="0,0,0,10"/>
            <TextBlock Text="Пароль:" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10"/>
            <TextBlock Text="Имя:" Margin="0,0,0,5"/>
            <TextBox x:Name="FirstNameBox" Margin="0,0,0,10"/>
            <TextBlock Text="Фамилия:" Margin="0,0,0,5"/>
            <TextBox x:Name="LastNameBox" Margin="0,0,0,10"/>
            <Button Content="Зарегистрироваться" Click="Register_Click" Width="200" Height="35" HorizontalAlignment="Center" Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Page>