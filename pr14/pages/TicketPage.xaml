<Page x:Class="pr14.Pages.TicketPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оформление билета">
    <Grid>
        <StackPanel Width="400" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Подтверждение покупки" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock x:Name="MovieText" Margin="0,0,0,5"/>
            <TextBlock x:Name="HallText" Margin="0,0,0,5"/>
            <TextBlock x:Name="DateTimeText" Margin="0,0,0,5"/>
            <TextBlock x:Name="SeatText" Margin="0,0,0,5"/>
            <TextBlock x:Name="PriceText" Margin="0,0,0,20" FontWeight="Bold"/>
            <Button Content="Подтвердить покупку" Click="Confirm_Click" Width="200" Height="40" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>