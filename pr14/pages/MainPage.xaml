<Page x:Class="pr14.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr14.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainPage">

    <DockPanel>

        <!-- Верхняя панель -->
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Top"
                    Margin="10">

            <TextBox x:Name="SearchBox"
                     Width="250"
                     Height="30"
                     Margin="0,0,10,0"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="SortBox"
                      Width="150"
                      Height="30"
                      SelectionChanged="SortBox_SelectionChanged">
                <ComboBoxItem Content="Без сортировки"/>
                <ComboBoxItem Content="По названию"/>
                <ComboBoxItem Content="По рейтингу"/>
            </ComboBox>

            <Button Content="Личный кабинет"
                    Width="150"
                    Height="30"
                    Margin="20,0,0,0"
                    Click="Account_Click"/>
        </StackPanel>

        <!-- Сетка фильмов -->
        <ScrollViewer>
            <ItemsControl x:Name="MoviesList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="1"
                                BorderBrush="Gray"
                                Margin="10"
                                Padding="5"
                                Width="180">

                            <StackPanel>

                                <Image Source="{Binding ImagePath}"
                                       Height="220"
                                       Stretch="UniformToFill"/>

                                <TextBlock Text="{Binding Title}"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0"/>

                                <TextBlock Text="Рейтинг:"/>
                                <TextBlock Text="{Binding Rating}"/>

                                <TextBlock Text="Возраст:"/>
                                <TextBlock Text="{Binding AgeRating}"/>

                                <Button Content="Подробнее"
                                        Margin="0,5,0,0"
                                        Tag="{Binding MovieID}"
                                        Click="Details_Click"/>
                            </StackPanel>

                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Page>
