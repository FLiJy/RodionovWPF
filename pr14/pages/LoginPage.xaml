<Page x:Class="pr14.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход">
    <Grid>
        <StackPanel Width="350" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Вход в аккаунт" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="Email:" Margin="0,0,0,5"/>
            <TextBox x:Name="EmailBox" Margin="0,0,0,5"/>
            <TextBlock Text="Пароль:" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,20"/>
            <Button Content="Войти" Click="Login_Click" Width="150" Height="35" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>