<Page x:Class="PR14.Pages.SessionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PR14.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SessionPage">

    <DockPanel>

        <TextBlock x:Name="SessionInfoText"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="10"
                   DockPanel.Dock="Top"/>

        <ScrollViewer Height="400" Width="610">
            <WrapPanel x:Name="SeatsPanel"
                       Margin="10"/>
        </ScrollViewer>

        <Button Content="Оформить билет"
                Height="107"
                Margin="10"
                DockPanel.Dock="Top"
                Click="Checkout_Click" Width="150"/>

        <Button Content="Главное меню"
                Height="35"
                Margin="10"
                Click="Main_Click" Width="158"/>


    </DockPanel>

</Page>
