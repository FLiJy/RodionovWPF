<Window x:Class="PR15.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сборка ПК" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2C3E50" Height="50">
            <Button Content="🔧 Конфигуратор" Click="BtnBuilder_Click" 
                    Padding="15,10" Margin="10,5" 
                    Background="#3498DB" Foreground="White"
                    BorderThickness="0" FontSize="14"/>
            <Button Content="📁 Сохранённые сборки" Click="BtnAssemblies_Click" 
                    Padding="15,10" Margin="5" 
                    Background="#3498DB" Foreground="White"
                    BorderThickness="0" FontSize="14"/>
        </StackPanel>

        <ContentControl Grid.Row="1" x:Name="MainFrame"/>

        <StatusBar Grid.Row="2" Background="#ECF0F1">
            <TextBlock x:Name="StatusText" Text="Готов к работе" Padding="10,5"/>
        </StatusBar>
    </Grid>
</Window>