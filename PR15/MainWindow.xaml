<Window x:Class="PR15.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Builder Pro" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковая панель навигации -->
        <Border Grid.Column="0" Background="#2C3E50" CornerRadius="0,15,15,0">
            <StackPanel Margin="20,40,20,20">
                <TextBlock Text="🖥️ PC Builder" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,0,0,40"
                           HorizontalAlignment="Center"/>

                <Button Content="🔧 Конфигуратор" 
                        Click="BtnBuilder_Click" 
                        Padding="15,12" 
                        Margin="0,10" 
                        Background="#3498DB" 
                        Foreground="White"
                        BorderThickness="0" 
                        FontSize="14"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="8" 
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2980B9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="📁 Сохранённые сборки" 
                        Click="BtnAssemblies_Click" 
                        Padding="15,12" 
                        Margin="0,10" 
                        Background="#3498DB" 
                        Foreground="White"
                        BorderThickness="0" 
                        FontSize="14"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="8" 
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2980B9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <StackPanel VerticalAlignment="Bottom" Margin="0,40,0,0">
                    <TextBlock x:Name="StatusText" 
                               Text="Готов к работе" 
                               Foreground="#BDC3C7" 
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Основная область контента -->
        <Frame Grid.Column="1" x:Name="MainFrame" 
               NavigationUIVisibility="Hidden"
               JournalOwnership="OwnsJournal"/>
    </Grid>
</Window>