<Page x:Class="PR15.Pages.BuilderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Конфигуратор"
      Background="#F5F6FA">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="🛠️ Сборка ПК" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - Каталог компонентов -->
            <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20" Margin="0,0,15,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Фильтры -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBox x:Name="TxtSearch" 
                                 Width="250" 
                                 Margin="0,0,15,0" 
                                 TextChanged="TxtSearch_TextChanged"
                                 Padding="10,8">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="White" 
                                                        BorderBrush="#DDDDDD" 
                                                        BorderThickness="1" 
                                                        CornerRadius="8">
                                                    <ScrollViewer x:Name="PART_ContentHost" 
                                                                  Margin="5"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <ComboBox x:Name="CboType" 
                                  Width="180" 
                                  Margin="0,0,15,0" 
                                  DisplayMemberPath="name"
                                  SelectionChanged="CboType_SelectionChanged"
                                  Padding="10,8">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ComboBox">
                                                <Border Background="White" 
                                                        BorderBrush="#DDDDDD" 
                                                        BorderThickness="1" 
                                                        CornerRadius="8">
                                                    <ContentPresenter Margin="5"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>

                        <ComboBox x:Name="CboManufacturer" 
                                  Width="180" 
                                  DisplayMemberPath="name"
                                  SelectionChanged="CboManufacturer_SelectionChanged"
                                  Padding="10,8"/>
                    </StackPanel>

                    <!-- Список компонентов -->
                    <DataGrid Grid.Row="1" 
                              x:Name="DgParts" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              SelectionChanged="DgParts_SelectionChanged"
                              CanUserAddRows="False" 
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              RowHeight="80">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#3498DB"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E8F4FD"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Фото" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Margin="5">
                                            <Image Source="{Binding image}" 
                                                   Width="70" 
                                                   Height="70" 
                                                   Stretch="Uniform"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Название" Binding="{Binding name}" Width="*"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="250"/>
                            <DataGridTextColumn Header="Производитель" Binding="{Binding manufacturer.name}" Width="120"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding price, StringFormat={}{0:N0} ₽}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Правая панель - Текущая сборка -->
            <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="20" Margin="15,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="📦 Ваша сборка" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"
                               Margin="0,0,0,15"/>

                    <!-- Список выбранных компонентов -->
                    <Border Grid.Row="1" 
                            Background="#F8F9FA" 
                            CornerRadius="10" 
                            Padding="10"
                            Margin="0,0,0,15">
                        <ListBox x:Name="LbAssembly" 
                                 DisplayMemberPath="name"
                                 SelectionChanged="LbAssembly_SelectionChanged"
                                 BorderThickness="0"
                                 Background="Transparent">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3498DB"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E8F4FD"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Border>

                    <!-- Характеристики -->
                    <Border Grid.Row="2" 
                            Background="#FFF9E6" 
                            CornerRadius="10" 
                            Padding="12"
                            Margin="0,0,0,15">
                        <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtSpecs" 
                                       TextWrapping="Wrap" 
                                       Text="Выберите компонент"
                                       Foreground="#2C3E50"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Итого -->
                    <Border Grid.Row="3" 
                            Background="#E8F8F5" 
                            CornerRadius="10" 
                            Padding="15"
                            Margin="0,0,0,15">
                        <TextBlock x:Name="TxtTotalPrice" 
                                   FontWeight="Bold" 
                                   FontSize="20" 
                                   Foreground="#27AE60"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Ошибки совместимости -->
                    <TextBlock x:Name="TxtErrors" 
                               Grid.Row="4"
                               Foreground="#E74C3C" 
                               TextWrapping="Wrap" 
                               Margin="0,0,0,15"
                               FontWeight="Bold"
                               FontSize="13"/>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="5" Orientation="Vertical">
                        <Button Content="💾 Сохранить сборку" 
                                Click="BtnSave_Click" 
                                Padding="15,12" 
                                Margin="0,0,0,10"
                                Background="#27AE60" 
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        CornerRadius="8" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#229954"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="🗑️ Очистить сборку" 
                                Click="BtnClear_Click" 
                                Padding="15,12"
                                Background="#E74C3C" 
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        CornerRadius="8" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#C0392B"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>